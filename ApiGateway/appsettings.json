{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },
      "project-route": {
        "ClusterId": "project-cluster",
        "Match": {
          "Path": "/api/v1/projects/{**catch-all}"
        }
      },
      "document-route": {
        "ClusterId": "document-cluster",
        "Match": {
          "Path": "/api/v1/document/{**catch-all}"
        }
      },
      "chat-route": {
        "ClusterId": "chat-cluster",
        "Match": {
          "Path": "/api/v1/chat/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5200/" }
        }
      },
      "project-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5002/" }
        }
      },
      "document-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5026/" }
        }
      },
      "chat-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5109/" }
        }
      }
    }
  },
  "RateLimiting": {
    "Global": {
      "Capacity": 20,
      "RefillRate": 5
    },
    "Endpoints": [
      {
        "Path": "/api/chat/messages",
        "Capacity": 5,
        "RefillRate": 1
      },
      {
        "Path": "/api/documents/upload",
        "Capacity": 3,
        "RefillRate": 0.5
      },
      {
        "Path": "/api/auth",
        "Capacity": 10,
        "RefillRate": 1
      }
    ]
  }
}

